# Copy this file to ".env" (which is gitignored) and fill in your real values.
# The VS Code Python extension auto-loads ".env" when you Run/Debug a script,
# so scrapers/score_history.py can reach the private Turso store.
#
# Without these two vars set, db.py falls back to a LOCAL SQLite file.
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here
